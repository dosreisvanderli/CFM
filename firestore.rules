rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidTransaction(data) {
      return data.keys().hasAll(['description', 'amount', 'category', 'type', 'status', 'day', 'month', 'year'])
          && data.description is string && data.description.size() <= 200
          && data.amount is string && data.amount.size() <= 50
          && data.category is string && data.category.size() <= 100
          && data.type in ['INCOME', 'EXPENSE']
          && data.status in ['PENDENTE', 'PAGO']
          && data.day is number
          && data.month is number
          && data.year is number
          && (!('paidAtMonth' in data) || data.paidAtMonth == null || data.paidAtMonth is number)
          && (!('paidAtYear' in data) || data.paidAtYear == null || data.paidAtYear is number)
          && (!('groupId' in data) || data.groupId == null || (data.groupId is string && data.groupId.size() <= 100));
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      match /transactions/{transactionId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId; 
        allow create: if isSignedIn() && request.auth.uid == userId && isValidId(transactionId) && isValidTransaction(incoming()) && incoming().keys().size() >= 8 && incoming().keys().size() <= 11;
        allow update: if isSignedIn() && request.auth.uid == userId && isValidTransaction(incoming())
            && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'category', 'type', 'status', 'day', 'month', 'year', 'paidAtMonth', 'paidAtYear', 'groupId']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
